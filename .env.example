# 码途智伴环境配置文件

# ==================== 模型配置 ====================
# 选择使用的模型：True=本地Ollama模型，False=智谱AI云端模型
USE_LOCAL_MODEL=False

# 智谱AI API配置（当USE_LOCAL_MODEL=False时使用）
# 请在此处填入您的智谱AI API Key
# 获取方式：https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# 本地Ollama模型配置（当USE_LOCAL_MODEL=True时使用）
LOCAL_MODEL_URL=http://localhost:11434/api/generate
LOCAL_MODEL_NAME=qwen2.5:7b

# ==================== 数据库配置 ====================
# ChromaDB向量数据库路径
CHROMADB_PATH=./kb_data

# ==================== Redis配置（可选） ====================
# Redis缓存配置（默认禁用）
REDIS_ENABLED=False
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL=3600

# ==================== JWT认证配置 ====================
# JWT密钥（生产环境请修改为随机字符串）
JWT_SECRET=codecompanion-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ==================== Docker配置 ====================
# Java代码执行沙箱
DOCKER_JAVA_ENABLED=True
DOCKER_JAVA_IMAGE=eclipse-temurin:17-jdk
DOCKER_JAVA_TIMEOUT=10

# ==================== 日志配置 ====================
LOG_DIR=./logs
LOG_LEVEL=INFO

# ==================== 性能优化配置 ====================
USE_UVLOOP=False
USE_ORJSON=True

# ==================== 缓存配置 ====================
CACHE_NAMESPACE=code_companion
LRU_CACHE_MAXSIZE=1000
LRU_CACHE_TTL=3600